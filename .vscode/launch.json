{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/tab"
            ],
            "outFiles": [
                "${workspaceFolder}/tab/out/**/*.js"
            ],
            "preLaunchTask": "${defaultBuildTask}"
        }
    ]
}
