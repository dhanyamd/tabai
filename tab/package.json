{
  "name": "tabai",
  "displayName": "TabAI",
  "description": "ai coding completion agent",
  "version": "0.0.1",
  "publisher": "dhanyamd",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "TabAI",
      "properties": {
        "tabai.openrouterApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenRouter API key (checked first if set)."
        },
        "tabai.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key (used if OpenRouter key is not set)."
        },
        "tabai.fireworksApiKey": {
          "type": "string",
          "default": "",
          "description": "Fireworks API key (used if OpenRouter and Groq keys are not set)."
        },
        "tabai.model": {
          "type": "string",
          "default": "qwen/qwen3-32b",
          "description": "Model ID sent to the active API provider."
        },
        "tabai.maxTokens": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "description": "Maximum tokens per completion request."
        },
        "tabai.completionCacheMaxEntries": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "description": "Maximum number of cached inline completions."
        },
        "tabai.completionCacheTtlMs": {
          "type": "number",
          "default": 30000,
          "minimum": 0,
          "description": "Time-to-live for cached completions, in milliseconds."
        },
        "tabai.lspCacheMaxEntries": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "description": "Maximum number of cached LSP context entries."
        }
      }
    },
    "commands": [
      {
        "command": "tabai.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
